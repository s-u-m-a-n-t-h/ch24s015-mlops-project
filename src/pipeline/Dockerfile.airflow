FROM apache/airflow:2.7.1-python3.10

USER root
RUN apt-get update && apt-get install -y git && apt-get clean

USER airflow
RUN pip install --no-cache-dir --upgrade pip

# Stable dependencies (heavy, rarely change)
RUN pip install --no-cache-dir pandas yfinance dvc[http]

# ML dependencies (likely to change during experimentation)
RUN pip install --no-cache-dir "numpy<2.0" mlflow scikit-learn email-validator
